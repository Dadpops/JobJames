# Backend API URL — required for production deployments where frontend and backend
# are on separate domains (e.g. Railway services).
#
# Development: leave unset — Vite proxies /api/* to localhost:8000 automatically.
# Production:  set to your backend Railway URL, e.g.:
#   VITE_API_URL=https://jobjames-backend.up.railway.app
#
# This value is baked into the frontend build at compile time (Vite env var).
VITE_API_URL=
