# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON list of allowed frontend origins.
# In production add your Railway frontend URL.
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost"]

# ── Database ───────────────────────────────────────────────────────────────────
# Local dev: leave as-is — uses SQLite (jobjames.db in the backend directory).
DATABASE_URL=jobjames.db

# Production (Railway): set to your PostgreSQL plugin connection string.
# Railway provides this automatically as DATABASE_URL when you add a Postgres plugin.
# Format: postgres://user:password@host.railway.internal:5432/railway
# DATABASE_URL=postgres://user:password@host.railway.internal:5432/railway

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=JobJames <onboarding@resend.dev>

# ── LinkedIn crawler (optional) ────────────────────────────────────────────────
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ── Job board company lists (optional) ────────────────────────────────────────
GREENHOUSE_COMPANIES=
LEVER_COMPANIES=

# ── SMTP (optional — falls back to Resend if not set) ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=JobJames <you@gmail.com>
SMTP_TLS=true
