# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON list of allowed frontend origins.
# In production add your Railway frontend URL.
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost"]

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite file path, or a sqlite:/// URI.
# For Railway: set to /data/jobjames.db and mount a Railway volume at /data.
# PostgreSQL support requires migrating from aiosqlite to SQLAlchemy (Phase 5).
DATABASE_URL=jobjames.db

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Sender address — use onboarding@resend.dev for testing (only sends to your Resend account email).
# For production: verify your domain at https://resend.com/domains and set e.g.:
# EMAIL_FROM=JobJames <noreply@yourdomain.com>
EMAIL_FROM=JobJames <onboarding@resend.dev>

# ── LinkedIn crawler (optional) ────────────────────────────────────────────────
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ── Job board company lists (optional) ────────────────────────────────────────
# Comma-separated Greenhouse board tokens (e.g. stripe,airbnb,figma)
GREENHOUSE_COMPANIES=
# Comma-separated Lever company slugs (e.g. netflix,spotify)
LEVER_COMPANIES=

# ── SMTP (optional — falls back to Resend if not set) ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=JobJames <you@gmail.com>
SMTP_TLS=true
